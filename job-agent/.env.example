OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL_FAST=anthropic/claude-3.5-haiku
OPENROUTER_MODEL_STRONG=anthropic/claude-3.5-sonnet
# Optional: if OpenRouter returns 404 for a model id, the client tries these next
OPENROUTER_MODEL_FALLBACK_FAST=
OPENROUTER_MODEL_FALLBACK_STRONG=
OPENROUTER_MAX_RETRIES=3
